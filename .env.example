# ==========================================================================
# Artifex360 -- Environment Variables
# ==========================================================================
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by python-dotenv at startup.
# It is listed in .gitignore and will NOT be committed.
# ==========================================================================

# Anthropic API Key (recommended over storing in config.json)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Server port (default: 8080)
# PORT=8080

# Optional: Server host (default: 0.0.0.0)
# HOST=0.0.0.0

# Optional: API authentication token (TASK-053)
# When set, non-localhost requests to /api/* must include an
# "Authorization: Bearer <token>" header.  Localhost requests are
# always allowed regardless of this setting.
# API_TOKEN=your-random-secret-token-here

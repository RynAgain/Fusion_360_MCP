2026-04-11 14:52:12,805  INFO      mcp.server -- MCP execute_tool: execute_script  inputs={'script': '# Get all bodies in the root component\nroot = rootComp\nbodies = root.bRepBodies\n\nprint(f"Found {bodies.count} bodies in the design:")\n\n# Create a separate component for each body\nfor i in range(bodies.count):\n    body = bodies.item(i)\n    print(f"Body {i}: {body.name} - Volume: {body.volume:.2f} cm³")\n    \n    # Create a new component\n    comp_name = f"Component_{body.name}"\n    occ = root.occurrences.addNewComponent(adsk.core.Matrix3D.create())\n    new_comp = occ.component\n    new_comp.name = comp_name\n    \n    # Copy the body to the new component\n    # Note: We need to use the move/copy feature to transfer the body\n    \n    # Create a copy of the body in the new component\n    copy_bodies = adsk.core.ObjectCollection.create()\n    copy_bodies.add(body)\n    \n    # Use the combine feature to copy the body to new component\n    combine_input = root.features.combineFeatures.createInput(\n        body,  # target body\n        copy_bodies  # tool bodies\n    )\n    combine_input.operation = adsk.fusion.FeatureOperations.NewComponentFeatureOperation\n    combine_input.targetComponent = new_comp\n    \n    try:\n        combine_feature = root.features.combineFeatures.add(combine_input)\n        print(f"  -> Copied to component: {comp_name}")\n    except Exception as e:\n        print(f"  -> Failed to copy body {body.name}: {str(e)}")\n\n# Alternative approach - move each body to its own component\nprint("\\nAlternative: Moving bodies to separate components...")\n\n# Get updated body list\nbodies = root.bRepBodies\nfor i in range(bodies.count):\n    body = bodies.item(i)\n    \n    # Create new component\n    occ = root.occurrences.addNewComponent(adsk.core.Matrix3D.create())\n    new_comp = occ.component\n    new_comp.name = f"Separated_{body.name}"\n    \n    # Move the body to the new component\n    try:\n        # Use moveToComponent method if available\n        if hasattr(body, \'moveToComponent\'):\n            body.moveToComponent(new_comp)\n            print(f"Moved {body.name} to component {new_comp.name}")\n        else:\n            print(f"moveToComponent not available for {body.name}")\n    except Exception as e:\n        print(f"Failed to move {body.name}: {str(e)}")\n\nprint(f"\\nFinal component count: {root.occurrences.count}")'}

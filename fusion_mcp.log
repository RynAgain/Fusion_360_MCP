2026-04-11 14:52:36,994  INFO      mcp.server -- MCP execute_tool: execute_script  inputs={'script': '# Use a simpler approach - copy bodies to new positions using combine feature\n\nroot = rootComp\nbodies = root.bRepBodies\n\nprint(f"Separating {bodies.count} bodies by copying them to new positions:")\n\noriginal_bodies = []\n# Store references to original bodies\nfor i in range(bodies.count):\n    body = bodies.item(i)\n    original_bodies.append({\n        \'body\': body, \n        \'name\': body.name,\n        \'volume\': body.volume\n    })\n    print(f"Original body {i}: {body.name} - Volume: {body.volume:.2f} cm³")\n\nspacing = 10.0  # cm between bodies\n\n# Create copies at different positions\nfor i, body_info in enumerate(original_bodies):\n    if i == 0:\n        continue  # Leave first body at original position\n    \n    body = body_info[\'body\']\n    \n    # Create a transform for the new position\n    transform = adsk.core.Matrix3D.create()\n    transform.translation = adsk.core.Vector3D.create(i * spacing, 0, 0)\n    \n    # Create collection with the body to copy\n    input_entities = adsk.core.ObjectCollection.create()\n    input_entities.add(body)\n    \n    # Use move feature with correct API\n    move_features = root.features.moveFeatures\n    move_input = move_features.createInput(input_entities, transform)\n    \n    try:\n        move_feature = move_features.add(move_input)\n        print(f"Moved {body.name} to X = {i * spacing} cm")\n    except Exception as e:\n        print(f"Error moving {body.name}: {str(e)}")\n        # Try alternative approach with copy feature instead\n        try:\n            # Use copy/paste features\n            copy_features = root.features.copyPasteFeatures\n            copy_input = copy_features.createInput(input_entities)\n            copy_input.transform = transform\n            copy_feature = copy_features.add(copy_input)\n            print(f"Copied {body.name} to X = {i * spacing} cm")\n        except Exception as e2:\n            print(f"Also failed to copy {body.name}: {str(e2)}")\n\n# Check final state\nprint(f"\\nFinal body count: {root.bRepBodies.count}")\nprint("Bodies are now separated along the X-axis")'}

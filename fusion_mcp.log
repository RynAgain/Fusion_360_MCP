2026-04-11 14:51:31,451  INFO      mcp.server -- MCP execute_tool: execute_script  inputs={'script': 'import math\n\n# Create a dodecahedron approximation using a pentagonal base\nroot = rootComp\n\n# Create the main pentagonal body first\nsketch = root.sketches.add(root.xYConstructionPlane)\nlines = sketch.sketchCurves.sketchLines\n\n# Regular pentagon parameters\nradius = 2.5  # cm\ncenter_x, center_y = 0, 0\n\n# Create pentagon vertices\npoints = []\nfor i in range(5):\n    angle = i * 2 * math.pi / 5 - math.pi/2  # Start from top\n    x = center_x + radius * math.cos(angle)\n    y = center_y + radius * math.sin(angle)\n    points.append(adsk.core.Point3D.create(x, y, 0))\n\n# Draw the pentagon\nfor i in range(5):\n    lines.addByTwoPoints(points[i], points[(i + 1) % 5])\n\n# Extrude the pentagon to create the main body\nif sketch.profiles.count > 0:\n    profile = sketch.profiles.item(0)\n    extInput = root.features.extrudeFeatures.createInput(\n        profile,\n        adsk.fusion.FeatureOperations.NewBodyFeatureOperation\n    )\n    # Use golden ratio for height\n    height = radius * 1.618\n    extInput.setDistanceExtent(False, adsk.core.ValueInput.createByReal(height))\n    base_feature = root.features.extrudeFeatures.add(extInput)\n    \n    if base_feature.bodies.count > 0:\n        body = base_feature.bodies.item(0)\n        body.name = "Dodecahedron"\n\n# Add beveled edges to approximate dodecahedral geometry\n# Create chamfers on the top and bottom edges\n\nbody = root.bRepBodies.item(0)\nif body:\n    # Find edges on the top face for chamfering\n    top_edges = adsk.core.ObjectCollection.create()\n    \n    # Get edges at the top of the pentagonal prism\n    for i in range(body.edges.count):\n        edge = body.edges.item(i)\n        # Check if edge is at the top (Z coordinate around the height)\n        bbox = edge.boundingBox\n        if abs(bbox.maxPoint.z - height) < 0.01:  # Top edges\n            top_edges.add(edge)\n    \n    if top_edges.count > 0:\n        # Create chamfer on top edges\n        chamfer_input = root.features.chamferFeatures.createInput2()\n        chamfer_input.chamferEdgeSets.addEqualDistanceChamferEdgeSet(\n            top_edges,\n            adsk.core.ValueInput.createByReal(0.5),  # 5mm chamfer\n            True\n        )\n        root.features.chamferFeatures.add(chamfer_input)\n    \n    # Do the same for bottom edges\n    bottom_edges = adsk.core.ObjectCollection.create()\n    for i in range(body.edges.count):\n        edge = body.edges.item(i)\n        bbox = edge.boundingBox\n        if abs(bbox.minPoint.z) < 0.01:  # Bottom edges\n            bottom_edges.add(edge)\n    \n    if bottom_edges.count > 0:\n        chamfer_input2 = root.features.chamferFeatures.createInput2()\n        chamfer_input2.chamferEdgeSets.addEqualDistanceChamferEdgeSet(\n            bottom_edges,\n            adsk.core.ValueInput.createByReal(0.5),  # 5mm chamfer\n            True\n        )\n        root.features.chamferFeatures.add(chamfer_input2)\n\nprint(f"Created dodecahedron approximation:")\nprint(f"Pentagon radius: {radius} cm")\nprint(f"Height: {height:.2f} cm")\nprint("Applied chamfers to top and bottom edges")\nprint("This approximates a dodecahedron with pentagonal faces and angled edges")'}

pu = dx*bx + dy*by + dz*bz\n        pv = dx*vx + dy*vy + dz*vz\n        return math.atan2(pv, pu)\n    \n    paired = sorted(zip(indices, pts), key=lambda x: angle(x[1]))\n    return [x[0] for x in paired]\n\nordered_faces = [order_face(list(f)) for f in face_set]\n\n# Create planar patch for each face, then stitch\npatches = []\nfor face_indices in ordered_faces:\n    loop_pts = [adsk.core.Point3D.create(verts[i][0], verts[i][1], verts[i][2]) for i in face_indices]\n    \n    # Create curves for the pentagon edges\n    curves = []\n    for k in range(5):\n        line = adsk.core.Line3D.create(loop_pts[k], loop_pts[(k+1)%5])\n        curves.append(line)\n    \n    # Create wire from curves\n    wire, _ = tbm.createWireFromCurves(curves, True)\n    \n    # Create face from planar wire using the correct API method\n    patch = tbm.createFaceFromPlanarWires([wire])\n    patches.append(patch)\n\nprint(f"Created {len(patches)} pentagonal faces")\n\n# Stitch into solid\ntry:\n    stitched = tbm.stitchSurfaces(patches, 0.001, None)\n    \n    if stitched:\n        result = root.bRepBodies.add(stitched, adsk.fusion.FeatureOperations.NewBodyFeatureOperation)\n        result.name = "Dodecahedron_10mm_Perfect"\n        print("✅ Perfect dodecahedron created successfully!")\n        print(f"   • 12 pentagonal faces")\n        print(f"   • 30 edges")  \n        print(f"   • 20 vertices")\n        print(f"   • Edge length: {edge_d:.4f} cm (10mm)")\n        \n        # Calculate properties\n        volume = result.volume\n        surface_area = result.area\n        bb = result.boundingBox\n        max_dim = max(bb.maxPoint.x - bb.minPoint.x,\n                     bb.maxPoint.y - bb.minPoint.y, \n                     bb.maxPoint.z - bb.minPoint.z)\n        \n        print(f"   • Volume: {volume:.3f} cm³")\n        print(f"   • Surface area: {surface_area:.3f} cm²")\n        print(f"   • Maximum dimension: {max_dim:.3f} cm")\n        \n    else:\n        print("❌ Stitch failed — adding patches individually")\n        for i, p in enumerate(patches):\n            body = root.bRepBodies.add(p, adsk.fusion.FeatureOperations.NewBodyFeatureOperation)\n            body.name = f"Pentagon_Face_{i+1}"\n        print(f"Created {len(patches)} individual pentagonal faces")\n\nexcept Exception as e:\n    print(f"❌ Error during stitching: {str(e)}")\n    print("Adding patches individually for inspection...")\n    for i, p in enumerate(patches):\n        try:\n            body = root.bRepBodies.add(p, adsk.fusion.FeatureOperations.NewBodyFeatureOperation)\n            body.name = f"Pentagon_Face_{i+1}"\n        except Exception as e2:\n            print(f"Failed to add face {i+1}: {str(e2)}")'}

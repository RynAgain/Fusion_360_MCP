scale, 0, z * scale))\n\nprint(f"Generated {len(vertices)} vertices for dodecahedron")\n\n# Since creating the exact 12-faced dodecahedron requires complex face operations,\n# I\'ll create a close approximation using a multi-step approach\n\n# First, create a bounding sphere that contains all vertices\nmax_radius = max(math.sqrt(x*x + y*y + z*z) for x, y, z in vertices)\nprint(f"Bounding radius: {max_radius:.3f} cm")\n\n# Create the base solid using multiple box intersections\n# This will approximate the dodecahedron shape\n\n# Start with a larger cube and cut it down\nbase_size = max_radius * 1.2\n\n# Create base cube\ncube_sketch = rootComp.sketches.add(rootComp.xYConstructionPlane)\ncube_sketch.name = "Dodeca_Base"\n\n# Create square for cube base\ncube_sketch.sketchCurves.sketchLines.addTwoPointRectangle(\n    adsk.core.Point3D.create(-base_size, -base_size, 0),\n    adsk.core.Point3D.create(base_size, base_size, 0)\n)\n\n# Extrude the cube\nif cube_sketch.profiles.count > 0:\n    cube_profile = cube_sketch.profiles.item(0)\n    cube_ext = rootComp.features.extrudeFeatures.createInput(\n        cube_profile,\n        adsk.fusion.FeatureOperations.NewBodyFeatureOperation\n    )\n    cube_ext.setDistanceExtent(False, adsk.core.ValueInput.createByReal(base_size * 2))\n    cube_feature = rootComp.features.extrudeFeatures.add(cube_ext)\n    \n    if cube_feature.bodies.count > 0:\n        base_body = cube_feature.bodies.item(0)\n        base_body.name = "Dodecahedron"\n        print("Created base cube")\n        \n        # Now apply cuts to approximate the dodecahedron faces\n        # Create cutting planes at angles that approximate the pentagonal faces\n        \n        cut_count = 0\n        # Apply 12 cuts (one for each face of dodecahedron)\n        face_normals = [\n            (1, phi, 0), (-1, phi, 0), (1, -phi, 0), (-1, -phi, 0),\n            (0, 1, phi), (0, -1, phi), (0, 1, -phi), (0, -1, -phi),\n            (phi, 0, 1), (-phi, 0, 1), (phi, 0, -1), (-phi, 0, -1)\n        ]\n        \n        for i, (nx, ny, nz) in enumerate(face_normals[:6]):  # Apply first 6 cuts\n            # Normalize the normal vector\n            norm = math.sqrt(nx*nx + ny*ny + nz*nz)\n            nx, ny, nz = nx/norm, ny/norm, nz/norm\n            \n            # Create cutting sketch\n            if abs(nz) < 0.9:  # Use XY plane if normal isn\'t too vertical\n                cut_sketch = rootComp.sketches.add(rootComp.xYConstructionPlane)\n            else:\n                cut_sketch = rootComp.sketches.add(rootComp.xZConstructionPlane)\n            \n            cut_sketch.name = f"Cut_{i+1}"\n            \n            # Create cutting rectangle\n            cut_size = base_size * 1.5\n            offset = scale * 0.8  # Distance from center\n            \n            # Position the cut\n            cx = nx * offset\n            cy = ny * offset\n            \n            cut_sketch.sketchCurves.sketchLines.addTwoPointRectangle(\n                adsk.core.Point3D.create(cx - cut_size, cy - cut_size, 0),\n                adsk.core.Point3D.create(cx + cut_size, cy + cut_size, 0)\n            )\n            \n            # Apply the cut\n            if cut_sketch.profiles.count > 0:\n                cut_profile = cut_sketch.profiles.item(0)\n                cut_ext = rootComp.features.extrudeFeatures.createInput(\n                    cut_profile,\n                    adsk.fusion.FeatureOperations.CutFeatureOperation\n                )\n                cut_ext.setAllExtent(adsk.fusion.ExtentDirections.SymmetricExtentDirection)\n                \n                try:\n                    rootComp.features.extrudeFeatures.add(cut_ext)\n                    cut_count += 1\n                except:\n                    print(f"Cut {i+1} failed")\n        \n        print(f"Applied {cut_count} cuts to create dodecahedron approximation")\n        print(f"Target edge length: {edge_length} cm (10mm)")\n        print(f"Approximate dodecahedron created 
uld be edge length): {min_dist:.4f} cm")\n\n# Now create the dodecahedron using loft/sweep operations\n# First, create one pentagonal face as a reference\n\n# Calculate the center and orientation of one pentagonal face\n# The top face has vertices that are roughly at the same Z level\n\n# Find vertices that form the top pentagonal face\ntop_vertices = []\nz_threshold = scale * phi * 0.8  # Near the top\n\nfor i, (x, y, z) in enumerate(vertices):\n    if z > z_threshold:\n        top_vertices.append((x, y, z, i))\n\nprint(f"Top face vertices: {len(top_vertices)}")\n\n# If we have enough top vertices, create a pentagonal face\nif len(top_vertices) >= 5:\n    # Sort by angle around the center to get proper pentagon order\n    center_x = sum(v[0] for v in top_vertices) / len(top_vertices)\n    center_y = sum(v[1] for v in top_vertices) / len(top_vertices)\n    center_z = sum(v[2] for v in top_vertices) / len(top_vertices)\n    \n    print(f"Top face center: ({center_x:.3f}, {center_y:.3f}, {center_z:.3f})")\n    \n    # Sort vertices by angle around center\n    def angle_from_center(vertex):\n        x, y, z, idx = vertex\n        return math.atan2(y - center_y, x - center_x)\n    \n    top_vertices.sort(key=angle_from_center)\n    \n    # Create a sketch for the top pentagon\n    sketch = rootComp.sketches.add(rootComp.xYConstructionPlane)\n    sketch.name = "Pentagon_Top"\n    \n    # Project the vertices onto the XY plane and connect them\n    lines = sketch.sketchCurves.sketchLines\n    \n    # Create the pentagon outline\n    for i in range(5):\n        if i < len(top_vertices):\n            curr_v = top_vertices[i]\n            next_v = top_vertices[(i + 1) % len(top_vertices)]\n            \n            p1 = adsk.core.Point3D.create(curr_v[0], curr_v[1], 0)\n            p2 = adsk.core.Point3D.create(next_v[0], next_v[1], 0)\n            \n            lines.addByTwoPoints(p1, p2)\n    \n    print("Created top pentagon sketch")\n    \n    # Extrude the pentagon to create a pentagonal prism approximation\n    if sketch.profiles.count > 0:\n        profile = sketch.profiles.item(0)\n        \n        # Calculate the height needed for the dodecahedron\n        height = scale * phi * 1.2\n        \n        ext_input = rootComp.features.extrudeFeatures.createInput(\n            profile,\n            adsk.fusion.FeatureOperations.NewBodyFeatureOperation\n        )\n        ext_input.setDistanceExtent(False, adsk.core.ValueInput.createByReal(height))\n        \n        # Offset the start to center the solid\n        ext_input.startExtent = adsk.fusion.OffsetStartDefinition.create(\n            adsk.core.ValueInput.createByReal(-height/2)\n        )\n        \n        feature = rootComp.features.extrudeFeatures.add(ext_input)\n        \n        if feature.bodies.count > 0:\n            body = feature.bodies.item(0)\n            body.name = "Dodecahedron_Proper"\n            \n            print("Created pentagonal prism as dodecahedron base")\n            print(f"This represents a closer approximation to a true dodecahedron")\n            print(f"Target edge length: {edge_length} cm (10mm)")\n            print(f"Vertices calculated using golden ratio mathematics")\n            print("")\n            print("Note: A complete regular dodecahedron requires complex 3D")\n            print("construction of all 12 pentagonal faces, which would need")\n            print("advanced surface modeling techniques in Fusion 360.")\n            \n        else:\n            print("Failed to create pentagonal solid")\n    else:\n        print("Failed to create pentagon profile")\nelse:\n    print("Insufficient vertices found for pentagon construction")\n    print("Creating a geometric reference instead...")\n    \n    # Create a reference sphere with the correct circumradius\n    circumradius = scale * math.sqrt(3) * (1 + math.sqrt(5)) / 2\n    \n    # Create sphere sketch\n    sphere_sketch = rootComp.sketches.add(rootComp.xZConstructionPlane)\n    sphere_sketch.name = "Dodecahedron_Reference"\n    \n    # Create quarter circle for revolve\n    arcs = sphere_sketch.sketchCurves.sketchArcs\n    lines = sphere_sketch.sketchCurves.sketchLines\n    \n    # Create semicircle profile away from axis\n    start_pt = adsk.core.Point3D.create(circumradius, 0, 0)\n    mid_pt = adsk.core.Point3D.create(circumradius * math.cos(math.pi/4), 0, circumradius * math.sin(math.pi/4))\n    end_pt = adsk.core.Point3D.create(0, 0, circumradius)\n    \n    arc = arcs.addByThreePoints(start_pt, mid_pt, end_pt)\n    line1 = lines.addByTwoPoints(end_pt, adsk.core.Point3D.create(0, 0, 0))\n    line2 = lines.addByTwoPoints(adsk.core.Point3D.create(0, 0, 0), start_pt)\n    \n    print(f"Created reference with circumradius: {circumradius:.3f} cm")'}

2026-04-11 14:51:14,653  INFO      mcp.server -- MCP execute_tool: execute_script  inputs={'script': 'import math\n\n# Create a dodecahedron using a simplified approach\n# We\'ll create a pentagonal prism and then modify it to approximate a dodecahedron\n\nroot = rootComp\n\n# Create a sketch on XY plane for a regular pentagon\nsketch = root.sketches.add(root.xYConstructionPlane)\nlines = sketch.sketchCurves.sketchLines\n\n# Pentagon parameters\npentagon_radius = 2.0  # cm\ncenter_x, center_y = 0, 0\n\n# Calculate pentagon vertices\npentagon_points = []\nfor i in range(5):\n    angle = i * 2 * math.pi / 5  # 72 degrees between vertices\n    x = center_x + pentagon_radius * math.cos(angle)\n    y = center_y + pentagon_radius * math.sin(angle)\n    pentagon_points.append(adsk.core.Point3D.create(x, y, 0))\n\n# Draw the pentagon\nfor i in range(5):\n    lines.addByTwoPoints(pentagon_points[i], pentagon_points[(i + 1) % 5])\n\n# Extrude the pentagon to create a pentagonal prism\nif sketch.profiles.count > 0:\n    profile = sketch.profiles.item(0)\n    \n    # Extrude upward\n    extInput = root.features.extrudeFeatures.createInput(\n        profile,\n        adsk.fusion.FeatureOperations.NewBodyFeatureOperation\n    )\n    height = pentagon_radius * 1.618  # Use golden ratio for proportions\n    extInput.setDistanceExtent(False, adsk.core.ValueInput.createByReal(height))\n    prism_feature = root.features.extrudeFeatures.add(extInput)\n    \n    if prism_feature.bodies.count > 0:\n        body = prism_feature.bodies.item(0)\n        body.name = "Dodecahedron_Base"\n\n# Now create angled faces to approximate dodecahedron geometry\n# Create sketches on the side faces and cut at dodecahedral angles\n\n# For a true dodecahedron, each face meets others at 116.57 degrees\n# We\'ll create beveled edges to approximate this\n\n# Create a sketch for cutting the top at an angle\ncut_sketch = root.sketches.add(root.xZConstructionPlane)\ncut_lines = cut_sketch.sketchCurves.sketchLines\n\n# Create angled cut geometry\ncut_height = height * 0.8\ncut_width = pentagon_radius * 1.5\n\ncut_lines.addByTwoPoints(\n    adsk.core.Point3D.create(-cut_width, 0, cut_height),\n    adsk.core.Point3D.create(cut_width, 0, cut_height)\n)\ncut_lines.addByTwoPoints(\n    adsk.core.Point3D.create(cut_width, 0, cut_height),\n    adsk.core.Point3D.create(cut_width * 0.7, 0, height + 0.5)\n)\ncut_lines.addByTwoPoints(\n    adsk.core.Point3D.create(cut_width * 0.7, 0, height + 0.5),\n    adsk.core.Point3D.create(-cut_width * 0.7, 0, height + 0.5)\n)\ncut_lines.addByTwoPoints(\n    adsk.core.Point3D.create(-cut_width * 0.7, 0, height + 0.5),\n    adsk.core.Point3D.create(-cut_width, 0, cut_height)\n)\n\n# Extrude the cut profile to create angled faces\nif cut_sketch.profiles.count > 0:\n    cut_profile = cut_sketch.profiles.item(0)\n    cut_extInput = root.features.extrudeFeatures.createInput(\n        cut_profile,\n        adsk.fusion.FeatureOperations.CutFeatureOperation\n    )\n    cut_extInput.setAllExtent(adsk.fusion.ExtentDirections.PositiveExtentDirection)\n    root.features.extrudeFeatures.add(cut_extInput)\n\nprint("Created dodecahedron approximation:")\nprint(f"Pentagon base radius: {pentagon_radius} cm")\nprint(f"Height: {height:.2f} cm")\nprint("Note: This is a simplified dodecahedron with pentagonal base and angled cuts")\nprint("A perfect dodecahedron has 12 pentagonal faces meeting at specific angles")'}
